---
// src/components/shared/Navbar.astro
const toolLinks = [
  { href: '/cron-to-systemd-converter', label: 'Crontab to Systemd' },
  { href: '/env-to-json', label: 'Env to JSON Object' },
  { href: '/json-to-env', label: 'JSON to Env Object' },
  { href: '/pii-masker-log-scrubber', label: 'PII Masker & Scrubber' },
  { href: '/cidr-subnet-calculator', label: 'CIDR Subnet Calculator' },
  { href: '/csv-to-json-schema', label: 'CSV to JSON Schema' }
];
---

<header class="sticky top-0 z-50 w-full border-b border-neutral-200 bg-white/80 backdrop-blur-md">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6" aria-label="Global System Navigation">
    
    <a href="/" aria-label="ConfigDev — Go to homepage" class="flex items-center gap-2 font-bold tracking-tight text-neutral-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#D4AF37] focus-visible:ring-offset-2 rounded px-1">
      <img src="/icon.png" alt="" width="24" height="24" class="w-6 h-6 object-contain" /> ConfigDev
    </a>
    
    <!-- Shared Right Menu Links (Desktop Only) -->
    <div class="hidden md:flex items-center gap-6 text-sm font-medium">
      <a href="/" class="text-neutral-600 hover:text-neutral-900 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#D4AF37] rounded px-1">Home</a>
      <a 
        href="https://github.com/rayanahmax/ConfigDev" 
        target="_blank" 
        rel="noopener noreferrer"
        class="text-neutral-600 hover:text-neutral-900 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#D4AF37] rounded px-1 flex items-center gap-1.5"
        aria-label="View ConfigDev Source Code on GitHub"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
        View Source on GitHub
      </a>
      
      <!-- Interactive Dropdown Group Trigger Container -->
      <div class="relative group py-4">
        <button 
          type="button" 
          aria-expanded="false" 
          aria-haspopup="menu"
          class="flex items-center gap-1 text-neutral-600 group-hover:text-neutral-900 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#D4AF37] rounded px-1 cursor-pointer"
        >
          Tools
          <svg class="w-3 h-3 text-neutral-400 group-hover:text-neutral-600 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>

        <!-- Flyout Navigation Dropdown Box Panel Menu -->
        <div 
          role="menu"
          aria-label="Available Utilities Suite"
          class="absolute left-1/2 -translate-x-1/2 top-full w-56 rounded-xl border border-neutral-200 bg-white p-2 shadow-lg opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto group-focus-within:opacity-100 group-focus-within:pointer-events-auto transition-all duration-150 transform translate-y-1 group-hover:translate-y-0"
        >
          {toolLinks.map(tool => (
            <a 
              href={tool.href} 
              role="menuitem"
              class="block w-full rounded-lg px-3 py-2 text-left text-xs font-semibold text-neutral-600 hover:text-neutral-900 hover:bg-neutral-50 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#D4AF37]"
            >
              {tool.label}
            </a>
          ))}
        </div>
      </div>
      
      <!-- System Status Metric Indicator Badge -->
      <div class="hidden sm:flex items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-semibold text-emerald-700 border border-emerald-200" role="status">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500" aria-hidden="true"></span>
        Operational
      </div>
    </div>

    <!-- Mobile Hamburger Toggle Button -->
    <button
      type="button"
      id="mobile-menu-toggle"
      aria-label="Toggle Navigation Menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="flex md:hidden items-center justify-center p-2 rounded-lg text-neutral-600 hover:text-neutral-900 hover:bg-neutral-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#D4AF37] cursor-pointer"
    >
      <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Navigation Menu Dropdown Drawer -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-neutral-200 bg-white"
  >
    <div class="px-6 py-4 space-y-4 flex flex-col text-sm font-medium">
      <a href="/" class="text-neutral-600 hover:text-neutral-900 py-1 transition-colors">Home</a>
      
      <div class="border-t border-neutral-100 pt-3 pb-1">
        <span class="text-xs font-semibold text-neutral-400 uppercase tracking-wider block mb-2 px-1">Tools</span>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 pl-2">
          {toolLinks.map(tool => (
            <a 
              href={tool.href} 
              class="block py-1 text-xs text-neutral-600 hover:text-neutral-900 transition-colors"
            >
              {tool.label}
            </a>
          ))}
        </div>
      </div>
      
      <a href="/about-us" class="border-t border-neutral-100 pt-3 text-neutral-600 hover:text-neutral-900 py-1 transition-colors">About</a>
      <a href="https://github.com/rayanahmax/ConfigDev" target="_blank" rel="noopener noreferrer" class="text-neutral-600 hover:text-neutral-900 py-1 transition-colors flex items-center gap-1.5">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
        View ConfigDev Source Code on GitHub
      </a>
      
      <div class="flex items-center gap-1.5 pt-3 border-t border-neutral-100" role="status">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500" aria-hidden="true"></span>
        <span class="text-xs font-semibold text-emerald-700">Operational</span>
      </div>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleButton = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    if (toggleButton && mobileMenu && menuIcon && closeIcon) {
      toggleButton.addEventListener('click', () => {
        const isExpanded = toggleButton.getAttribute('aria-expanded') === 'true';
        toggleButton.setAttribute('aria-expanded', String(!isExpanded));
        mobileMenu.classList.toggle('hidden');
        menuIcon.classList.toggle('hidden');
        closeIcon.classList.toggle('hidden');
      });
    }
  });
</script>
