---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Internal Server Error | ConfigDev" noIndex={true}>
  <main class="w-full max-w-lg px-6 py-24 flex flex-col items-center justify-center flex-grow text-center animate-fadeIn">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-rose-50 border border-rose-200/80 text-rose-500 mb-6">
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
    </div>
    <h1 class="text-6xl font-extrabold text-neutral-900 tracking-tight leading-none mb-3">500</h1>
    <h2 class="text-2xl font-bold text-neutral-800 tracking-tight mb-4">Internal Server Error</h2>
    <p class="text-neutral-500 text-sm leading-relaxed max-w-sm mb-8">
      Something went wrong on our end. Please refresh the page, check your local memory status, or return to the main dashboard.
    </p>
    <a 
      href="/" 
      class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-sm font-semibold rounded-lg text-white bg-neutral-900 hover:bg-neutral-800 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-neutral-900 cursor-pointer active:scale-[0.98]"
    >
      Back to Dashboard
    </a>
  </main>
</Layout>
