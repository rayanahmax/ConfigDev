        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          <span class="text-sm font-bold text-emerald-900">Network: 0 Requests</span>
        </div>
      </div>

      {/* Transparency: How it Works */}
      <details class="group bg-neutral-50 border border-neutral-200 rounded-lg flex-1 min-w-[300px]">
        <summary class="flex items-center justify-between cursor-pointer px-4 py-4 text-sm font-bold text-neutral-800 marker:hidden">
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-neutral-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            Transparency: How It Works
          </span>
          <svg class="w-5 h-5 text-neutral-500 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </summary>
        <div class="px-4 pb-4">
          <pre class="bg-neutral-900 text-emerald-400 p-3 rounded text-xs overflow-x-auto font-mono">
<code>{`// Native Browser APIs (no external libraries)
window.btoa(str)  // Encode to Base64
window.atob(str)  // Decode from Base64

// Regex-based YAML parsing
/^[ \\t]*data:[ \\t]*\\r?\\n/m  // data: block
/^[ \\t]*stringData:[ \\t]*\\r?\\n/m  // stringData: block
/^[ \\t]+([a-zA-Z0-9._-]+):\\s*(.+)$/  // key: value pairs`}</code>
