---
import Layout from '../layouts/Layout.astro';
import CIDRCalculator from '../components/tools/CIDRCalculator';
import RelatedTools from '../components/shared/RelatedTools.astro';

const toolFaqs = [
  {
    question: "What is CIDR notation?",
    answer: "CIDR (Classless Inter-Domain Routing) notation is a compact way to represent an IP address and its associated network mask. For example, 192.168.1.0/24 represents the network 192.168.1.0 with a 24-bit prefix, giving 256 total addresses and 254 usable hosts."
  },
  {
    question: "How many usable hosts does a /24 subnet have?",
    answer: "A /24 subnet has 256 total addresses (2 to the power of 8), but 2 are reserved — the network address and the broadcast address — leaving 254 usable host addresses."
  },
  {
    question: "What is the difference between a network address and a broadcast address?",
    answer: "The network address is the first IP in a subnet (e.g., 192.168.1.0 in a /24) and identifies the subnet itself. The broadcast address is the last IP (e.g., 192.168.1.255) and is used to send packets to all hosts on the subnet. Neither can be assigned to individual hosts."
  },
  {
    question: "Is this subnet calculator safe for private infrastructure data?",
    answer: "Yes. The CIDR calculator runs 100% inside your browser's local JavaScript sandbox. No IP ranges, subnet parameters, or any data you enter is ever transmitted to a server, making it safe for planning private cloud VPCs and internal network topologies."
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "@id": "https://configdev.com/cidr-subnet-calculator",
      "url": "https://configdev.com/cidr-subnet-calculator",
      "name": "CIDR Subnet Calculator Online - Free & Secure",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "All",
      "browserRequirements": "Requires JavaScript. Runs entirely client-side inside local browser memory sandbox frameworks.",
      "description": "A free, web-based IPv4 subnet calculator running entirely client-side. Instantly parse CIDR notation blocks, visually split IP ranges, and calculate subnet boundaries for AWS, GCP, and private server frames safely."
    },
    {
      "@type": "FAQPage",
      "@id": "https://configdev.com/cidr-subnet-calculator/#faq",
      "mainEntity": toolFaqs.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": { "@type": "Answer", "text": f.answer }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://configdev.com/" },
        { "@type": "ListItem", "position": 2, "name": "CIDR Subnet Calculator", "item": "https://configdev.com/cidr-subnet-calculator" }
      ]
    }
  ]
};
---

