            <tr><td class="px-4 py-2.5 font-bold text-neutral-900">/27</td><td class="px-4 py-2.5">255.255.255.224</td><td class="px-4 py-2.5">32</td><td class="px-4 py-2.5 text-emerald-600 font-bold">30</td></tr>
