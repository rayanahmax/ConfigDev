            <tr><td class="px-4 py-2.5 font-bold text-neutral-900">/25</td><td class="px-4 py-2.5">255.255.255.128</td><td class="px-4 py-2.5">128</td><td class="px-4 py-2.5 text-emerald-600 font-bold">126</td></tr>
