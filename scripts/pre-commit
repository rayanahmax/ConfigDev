#!/bin/sh

# Regex patterns for common third-party keys/IDs
PATTERNS="(G-[A-Z0-9]{8,}|UA-[0-9]+-[0-9]+|GTM-[A-Z0-9]+|google-site-verification.*content=[\"'][A-Za-z0-9_-]+[\"']|yandex-verification.*content=[\"'][0-9a-f]+[\"'])"

# Check if there are any staged changes
if git rev-parse --verify HEAD >/dev/null 2>&1
then
  against=HEAD
else
  # Initial commit: diff against an empty tree object
  against=4b825dc642cb6eb9a060e54bf8d69288fbee4904
fi

# Search the staged diff additions for the regex patterns
# We exclude the pre-commit script itself and .env.example to prevent self-matching and placeholder matching.
# We also run a case-sensitive grep to ensure 'G-' strictly matches uppercase, preventing accidental matches with words like 'log-scrubber'.
LEAKS=$(git diff --cached --diff-filter=ACM $against -- . ":(exclude)scripts/pre-commit" ":(exclude).env.example" | grep -E "^\+" | grep -E "$PATTERNS" | grep -v "G-XXXXXXXXXX")

if [ -n "$LEAKS" ]; then
  echo "=========================================================================="
  echo "🚨 SECRET LEAK DETECTED 🚨"
  echo "You are attempting to commit hardcoded tracking/verification identifiers!"
  echo ""
  echo "Matches found:"
  echo "$LEAKS" | sed 's/^+/  /'
  echo ""
  echo "Please move these variables to your .env file and use import.meta.env."
  echo "To bypass (not recommended), use git commit --no-verify"
  echo "=========================================================================="
  exit 1
fi

exit 0
